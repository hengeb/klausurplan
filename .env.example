# Datenbank
DB_HOST=localhost
DB_NAME=klausurplan
DB_USER=klausurplan_user
DB_PASS=

# LTI 1.3 – Plattformdaten (Platform-ID, Client-ID etc.) stehen in der DB (Setup-Assistent)
# Relativer Pfad (relativ zum Projektverzeichnis) oder absoluter Pfad
LTI_PRIVATE_KEY_FILE=private.key
LTI_KID=klausurplan-key-1

# Moodle REST API (für Nutzerimport)
MOODLE_URL=https://moodle.schule.de
MOODLE_API_TOKEN=

# SMTP
SMTP_HOST=mail.schule.de
SMTP_PORT=465
SMTP_ENCRYPTION=ssl
# SMTP_ENCRYPTION: 'ssl' für Port 465 (SSL/TLS), 'tls' für Port 587 (STARTTLS)
SMTP_USER=klausurplan@schule.de
SMTP_PASS=
SMTP_FROM_NAME=Klausurplan

# App
APP_URL=https://schule.de/klausurplan
APP_ENV=production

# Setup-Assistent (nach Abschluss entfernen!)
# Zugriff: /setup.php?token=<SETUP_TOKEN>
# SETUP_TOKEN=
