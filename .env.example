# Datenbank
DB_HOST=localhost
DB_NAME=klausurplan
DB_USER=klausurplan_user
DB_PASS=

# LTI 1.3
LTI_PLATFORM_ID=https://moodle.schule.de
LTI_CLIENT_ID=
LTI_DEPLOYMENT_ID=
LTI_KEY_SET_URL=https://moodle.schule.de/mod/lti/certs.php
LTI_AUTH_URL=https://moodle.schule.de/mod/lti/auth.php
LTI_TOKEN_URL=https://moodle.schule.de/mod/lti/token.php
# Relativer Pfad (relativ zum Projektverzeichnis) oder absoluter Pfad
LTI_PRIVATE_KEY_FILE=private.key
LTI_KID=klausurplan-key-1

# Moodle REST API (optional, für Nutzerimport)
MOODLE_URL=https://moodle.schule.de
MOODLE_API_TOKEN=

# SMTP
SMTP_HOST=mail.schule.de
SMTP_PORT=587
SMTP_USER=klausurplan@schule.de
SMTP_PASS=
SMTP_FROM_NAME=Klausurplan

# App
APP_URL=https://schule.de/klausurplan
APP_ENV=production

# Setup-Assistent (nach Abschluss entfernen!)
# Zugriff: /setup?token=<SETUP_TOKEN>
